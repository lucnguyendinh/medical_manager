# Copy this file to .env.local for local development,
# or set these as environment variables in production.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev (running MongoDB locally):
MONGODB_URI=mongodb://localhost:27017/medical_management
# Docker Compose (app talks to the mongo service):
# MONGODB_URI=mongodb://mongo:27017/medical_management
# MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/medical_management

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here


# Full URL of the app (required in production)
NEXTAUTH_URL=http://localhost:3000

# ── App settings ─────────────────────────────────────────────────────────────
# Gmail of the protected super-admin (cannot be deleted or demoted)
SUPER_ADMIN_GMAIL=superadmin@gmail.com

# ── Cloudinary (medical item images) ─────────────────────────────────────────
# Find these in your Cloudinary dashboard. The API secret is used server-side
# only to sign uploads; it is never sent to the browser.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Folder where uploaded images are stored (optional).
CLOUDINARY_UPLOAD_FOLDER=medical_management
